msgid ""
"We've sent you a link to reset your password. If it doesn't arrive in a few "
"minutes, check your spam folder."
msgstr ""
"Te hemos enviado un enlace para restablecer tu contraseña. Si no llega en "
"unos minutos, revisa tu carpeta de spam."

msgid ""
"This password reset link is invalid or has already been used. Please <a "
"href=\"%(reset_url)s\">request a new one</a>."
msgstr ""
"El enlace de restablecimiento no es válido o ya se ha usado. Por favor, <a "
"href=\"%(reset_url)s\">solicita uno nuevo</a>."

msgid ""
"We've sent you a verification link. Follow it to finish signing up. If it "
"doesn't arrive in a few minutes, check your spam folder."
msgstr ""
"Te hemos enviado un enlace de verificación. Síguelo para terminar el "
"registro. Si no llega en unos minutos, revisa tu carpeta de spam."

msgid "Confirm that %(email)s is your email address."
msgstr "Confirma que %(email)s es tu dirección de correo."

msgid ""
"This confirmation link expired or is invalid. Please <a "
"href=\"%(email_url)s\">request a new one</a>."
msgstr ""
"El enlace de confirmación caducó o no es válido. Por favor, <a "
"href=\"%(email_url)s\">solicita uno nuevo</a>."

msgid "Renews / valid until %(date)s."
msgstr "Se renueva / válido hasta %(date)s."

msgid ""
"This is a simulated checkout (dev provider) — no real payment is taken. "
"Amount: %(amount)s %(currency)s."
msgstr ""
"Este es un pago simulado (proveedor dev) — no se cobra dinero real. Importe:"
" %(amount)s %(currency)s."

msgid "XIRR %(x)s"
msgstr "XIRR %(x)s"

msgid ""
"Base-currency totals need FX rates for: %(cur)s. Per-asset figures below are"
" exact in each asset's own currency."
msgstr ""
"Los totales en moneda base necesitan tipos de cambio para: %(cur)s. Las "
"cifras por activo más abajo son exactas en la moneda de cada activo."

msgid "Allocation excludes positions in %(cur)s — no FX rate to %(base)s yet."
msgstr ""
"La distribución excluye posiciones en %(cur)s — aún sin tipo de cambio a "
"%(base)s."

msgid "Prices as of %(d)s UTC."
msgstr "Precios al %(d)s UTC."

msgid ""
"No quote yet for: %(tickers)s — click <strong>Refresh prices</strong> to "
"fetch."
msgstr ""
"Aún sin cotización para: %(tickers)s — pulsa <strong>Actualizar "
"precios</strong>."

