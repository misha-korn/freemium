# Copy to .env for local dev:  cp .env.example .env
# Never commit a real .env. Generate a secret key with:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"

# --- Core ---
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-dev-only
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=UTC

# --- Database ---
# Dev falls back to SQLite if unset. For Postgres (recommended / prod):
# DATABASE_URL=postgres://freemium:freemium@localhost:5432/freemium
DATABASE_URL=

# --- Cache / Celery (Stage 2) ---
REDIS_URL=
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# Run tasks inline in dev (no worker required):
CELERY_TASK_ALWAYS_EAGER=True
# Periodic price-refresh interval for Celery Beat, in seconds (default 900 = 15m):
MARKETDATA_REFRESH_SECONDS=900

# --- Email (prod uses SMTP; dev prints to console) ---
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@freemium.app

# --- Security (prod) ---
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_CSRF_TRUSTED_ORIGINS=

# --- Monitoring (prod, optional) ---
SENTRY_DSN=

# --- Market data providers (wired in Stage 2) ---
# MOEX ISS needs no key. International providers do:
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
TWELVE_DATA_API_KEY=

# --- Billing / subscriptions (Stage 4) ---
# Provider: "dev" simulates checkout/webhooks (no keys); use yookassa/stripe in prod.
BILLING_PROVIDER=dev
# Master switch for paid checkout. False (default) shows "coming soon" instead of
# a checkout button; set True once a real provider + keys are configured.
BILLING_ENABLED=False
PRO_PRICE_AMOUNT=499
PRO_PRICE_CURRENCY=RUB
PRO_PERIOD_DAYS=30
FREE_MAX_PORTFOLIOS=1
# Shared secret used to sign/verify webhooks (HMAC). Set a strong value in prod.
BILLING_WEBHOOK_SECRET=dev-webhook-secret
